(* ============================================================================
   完整推导主函数
   ============================================================================ *)
RunFullDerivation[] := Module[{},
  Print["\n===== 第1步: 格点场强张量 ====="];
  FieldStrengthTensorDerivation[];

  Print["\n===== 第2步: 梯度流重整化 ====="];
  GradientFlowDerivation[];

  Print["\n===== 第3步: 胶子准TMD算符 ====="];
  GluonQuasiTMDDerivation[];

  Print["\n===== 第4步: Staple Wilson线 ====="];
  StapleWilsonLineDerivation[];

  Print["\n===== 第5步: 重整化方案 ====="];
  RenormalizationDerivation[];

  Print["\n===== 第6步: LaMET因子化 ====="];
  LaMETFactorizationDerivation[];

  Print["\n===== 第7步: 连续极限外推 ====="];
  ContinuumExtrapolationDerivation[];

  Print["\n===== 第8步: 完整数值工作流 ====="];
  CompleteWorkflowDemo[];

  Print["\n========== 推导完成 =========="];
];
