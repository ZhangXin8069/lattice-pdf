                </elem>
            </BkwdProps>
            </BuildingBlocks>
            <xml_file>./iog/xml/pion_3pt_Px0Py0Pz0_ENV-1_conf10150_tsep10_mass-0.2770_linkdir2_linkmax10.xml</xml_file>
        </elem>
              

            </InlineMeasurements>    
            
            <nrow>24 24 24 72</nrow>
            
